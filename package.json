{
  "name": "goldos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "db:generate": "pnpm --filter @goldos/database db:generate",
    "db:migrate": "pnpm --filter @goldos/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @goldos/database db:migrate:deploy",
    "db:studio": "pnpm --filter @goldos/database db:studio",
    "db:seed": "pnpm --filter @goldos/database db:seed",
    "prepare": "husky",
    "ensure:utf8": "node scripts/ensure-utf8.cjs",
    "prebuild": "node scripts/ensure-utf8.cjs",
    "prelint": "node scripts/ensure-utf8.cjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3"
  }
}
