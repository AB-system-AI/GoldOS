{
  "name": "@goldos/database",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate --schema=./prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=./prisma",
    "db:studio": "prisma studio --schema=./prisma",
    "db:push": "prisma db push --schema=./prisma",
    "db:seed": "node prisma/seed.cjs",
    "db:format": "prisma format --schema=./prisma",
    "db:validate": "prisma validate --schema=./prisma",
    "postinstall": "prisma generate --schema=./prisma"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1"
  },
  "devDependencies": {
    "@goldos/eslint-config": "workspace:*",
    "@goldos/tsconfig": "workspace:*",
    "@types/node": "^22.12.0",
    "eslint": "^9.18.0",
    "prisma": "^6.3.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  }
}
