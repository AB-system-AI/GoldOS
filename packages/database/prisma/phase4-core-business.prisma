// ─── Phase 4: Core Business Foundation ───────────────────────────────────────

model Department {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  code        String    @db.VarChar(30)
  name        String    @db.VarChar(150)
  description String?   @db.Text
  parentId    String?   @map("parent_id") @db.Uuid
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Department[] @relation("DepartmentHierarchy")
  employees Employee[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
  @@index([tenantId, deletedAt])
  @@map("departments")
}

model JobTitle {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  code        String    @db.VarChar(30)
  name        String    @db.VarChar(150)
  description String?   @db.Text
  level       Int       @default(0)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("job_titles")
}

model EmployeeBranch {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  employeeId String    @map("employee_id") @db.Uuid
  branchId   String    @map("branch_id") @db.Uuid
  isDefault  Boolean   @default(false) @map("is_default")
  assignedAt DateTime  @default(now()) @map("assigned_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([employeeId, branchId])
  @@index([tenantId])
  @@index([employeeId])
  @@index([branchId])
  @@map("employee_branches")
}

model EmploymentHistory {
  id          String              @id @default(uuid()) @db.Uuid
  tenantId    String              @map("tenant_id") @db.Uuid
  employeeId  String              @map("employee_id") @db.Uuid
  eventType   EmploymentEventType @map("event_type")
  title       String              @db.VarChar(150)
  description String?             @db.Text
  branchId    String?             @map("branch_id") @db.Uuid
  department  String?             @db.VarChar(100)
  jobTitle    String?             @map("job_title") @db.VarChar(100)
  effectiveAt DateTime            @map("effective_at") @db.Timestamptz(6)
  metadata    Json                @default("{}")
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?           @map("deleted_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch   Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([employeeId])
  @@index([effectiveAt])
  @@map("employment_history")
}

