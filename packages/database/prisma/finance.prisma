// ─── Finance & Pricing ───────────────────────────────────────────────────────

model Currency {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.Char(3)
  name      String   @db.VarChar(100)
  symbol    String   @db.VarChar(10)
  decimals  Int      @default(2)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  exchangeRates ExchangeRate[]

  @@index([isActive])
  @@map("currencies")
}

model ExchangeRate {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String?  @map("tenant_id") @db.Uuid
  currencyId   String   @map("currency_id") @db.Uuid
  baseCurrency String   @default("SAR") @map("base_currency") @db.Char(3)
  rate         Decimal  @db.Decimal(18, 8)
  effectiveAt  DateTime @map("effective_at") @db.Timestamptz(6)
  source       String?  @db.VarChar(50)
  providerId   String?  @map("provider_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant   Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currency Currency             @relation(fields: [currencyId], references: [id], onDelete: Restrict)
  provider ExchangeRateProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([currencyId])
  @@index([providerId])
  @@index([effectiveAt])
  @@map("exchange_rates")
}

model GoldPriceHistory {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  karat       GoldKarat
  pricePerGram Decimal  @map("price_per_gram") @db.Decimal(12, 4)
  currency    String    @default("SAR") @db.Char(3)
  source      String    @db.VarChar(50)
  providerId  String?   @map("provider_id") @db.Uuid
  sourceId    String?   @map("source_id") @db.Uuid
  effectiveAt DateTime  @map("effective_at") @db.Timestamptz(6)
  isCurrent   Boolean   @default(false) @map("is_current")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider    GoldPriceProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  priceSource GoldPriceSource?   @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([tenantId, karat, isCurrent])
  @@index([providerId])
  @@index([sourceId])
  @@index([effectiveAt])
  @@map("gold_price_history")
}

model PricingRule {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  code        String          @db.VarChar(50)
  name        String          @db.VarChar(150)
  type        PricingRuleType
  conditions  Json            @default("{}")
  actions     Json            @default("{}")
  priority    Int             @default(0)
  isActive    Boolean         @default(true) @map("is_active")
  validFrom   DateTime?       @map("valid_from") @db.Timestamptz(6)
  validTo     DateTime?       @map("valid_to") @db.Timestamptz(6)
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?       @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([type])
  @@index([isActive])
  @@map("pricing_rules")
}

model TaxRule {
  id        String      @id @default(uuid()) @db.Uuid
  tenantId  String      @map("tenant_id") @db.Uuid
  code      String      @db.VarChar(50)
  name      String      @db.VarChar(150)
  type      TaxRuleType
  rate      Decimal     @db.Decimal(5, 2)
  isDefault Boolean     @default(false) @map("is_default")
  isActive  Boolean     @default(true) @map("is_active")
  metadata  Json        @default("{}")
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?   @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([isActive])
  @@map("tax_rules")
}

model Bank {
  id            String          @id @default(uuid()) @db.Uuid
  tenantId      String          @map("tenant_id") @db.Uuid
  name          String          @db.VarChar(150)
  accountName   String          @map("account_name") @db.VarChar(150)
  accountNumber String          @map("account_number") @db.VarChar(50)
  iban          String?         @db.VarChar(34)
  swiftCode     String?         @map("swift_code") @db.VarChar(11)
  accountType   BankAccountType @default(CHECKING) @map("account_type")
  currency      String          @default("SAR") @db.Char(3)
  balance       Decimal         @default(0) @db.Decimal(18, 4)
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?       @map("deleted_at") @db.Timestamptz(6)

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("banks")
}

model CashRegister {
  id         String             @id @default(uuid()) @db.Uuid
  tenantId   String             @map("tenant_id") @db.Uuid
  branchId   String             @map("branch_id") @db.Uuid
  name       String             @db.VarChar(100)
  code       String             @db.VarChar(20)
  status     CashRegisterStatus @default(CLOSED)
  currency   String             @default("SAR") @db.Char(3)
  openBalance Decimal           @default(0) @map("open_balance") @db.Decimal(18, 4)
  currentBalance Decimal        @default(0) @map("current_balance") @db.Decimal(18, 4)
  openedAt   DateTime?          @map("opened_at") @db.Timestamptz(6)
  closedAt   DateTime?          @map("closed_at") @db.Timestamptz(6)
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime?          @map("deleted_at") @db.Timestamptz(6)

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([branchId])
  @@index([status])
  @@map("cash_registers")
}

model Transaction {
  id             String            @id @default(uuid()) @db.Uuid
  tenantId       String            @map("tenant_id") @db.Uuid
  bankId         String?           @map("bank_id") @db.Uuid
  cashRegisterId String?           @map("cash_register_id") @db.Uuid
  transactionNo  String            @map("transaction_no") @db.VarChar(30)
  type           TransactionType
  status         TransactionStatus @default(PENDING)
  amount         Decimal           @db.Decimal(18, 4)
  currency       String            @default("SAR") @db.Char(3)
  description    String            @db.Text
  referenceType  String?           @map("reference_type") @db.VarChar(50)
  referenceId    String?           @map("reference_id") @db.Uuid
  occurredAt     DateTime          @map("occurred_at") @db.Timestamptz(6)
  metadata       Json              @default("{}")
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?         @map("deleted_at") @db.Timestamptz(6)

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  bank         Bank?         @relation(fields: [bankId], references: [id], onDelete: SetNull)
  cashRegister CashRegister? @relation(fields: [cashRegisterId], references: [id], onDelete: SetNull)

  @@unique([tenantId, transactionNo])
  @@index([tenantId])
  @@index([bankId])
  @@index([cashRegisterId])
  @@index([type])
  @@index([occurredAt])
  @@map("transactions")
}
