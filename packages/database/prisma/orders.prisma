// ─── Purchase & Sales Orders ─────────────────────────────────────────────────

model PurchaseOrder {
  id           String              @id @default(uuid()) @db.Uuid
  tenantId     String              @map("tenant_id") @db.Uuid
  branchId     String              @map("branch_id") @db.Uuid
  supplierId   String              @map("supplier_id") @db.Uuid
  orderNo      String              @map("order_no") @db.VarChar(30)
  status       PurchaseOrderStatus @default(DRAFT)
  orderDate    DateTime            @map("order_date") @db.Date
  expectedDate DateTime?           @map("expected_date") @db.Date
  currency     String              @default("SAR") @db.Char(3)
  subtotal     Decimal             @default(0) @db.Decimal(18, 4)
  taxAmount    Decimal             @default(0) @map("tax_amount") @db.Decimal(18, 4)
  totalAmount  Decimal             @default(0) @map("total_amount") @db.Decimal(18, 4)
  notes        String?             @db.Text
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?           @map("deleted_at") @db.Timestamptz(6)

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch   Branch              @relation(fields: [branchId], references: [id], onDelete: Restrict)
  supplier Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  lines    PurchaseOrderLine[]

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id              String    @id @default(uuid()) @db.Uuid
  purchaseOrderId String    @map("purchase_order_id") @db.Uuid
  productId       String    @map("product_id") @db.Uuid
  lineNo          Int       @map("line_no")
  quantity        Int       @default(1)
  unitCost        Decimal   @map("unit_cost") @db.Decimal(18, 4)
  totalCost       Decimal   @map("total_cost") @db.Decimal(18, 4)
  receivedQty     Int       @default(0) @map("received_qty")
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([purchaseOrderId, lineNo])
  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_lines")
}

model SalesOrder {
  id                    String           @id @default(uuid()) @db.Uuid
  tenantId              String           @map("tenant_id") @db.Uuid
  organizationId        String?          @map("organization_id") @db.Uuid
  branchId              String           @map("branch_id") @db.Uuid
  customerId            String           @map("customer_id") @db.Uuid
  employeeId            String?          @map("employee_id") @db.Uuid
  posSessionId          String?          @map("pos_session_id") @db.Uuid
  orderNo               String           @map("order_no") @db.VarChar(30)
  status                SalesOrderStatus @default(DRAFT)
  paymentStatus         PaymentStatus    @default(UNPAID) @map("payment_status")
  orderDate             DateTime         @map("order_date") @db.Date
  currency              String           @default("SAR") @db.Char(3)
  subtotal              Decimal          @default(0) @db.Decimal(18, 4)
  discountAmount        Decimal          @default(0) @map("discount_amount") @db.Decimal(18, 4)
  taxAmount             Decimal          @default(0) @map("tax_amount") @db.Decimal(18, 4)
  totalAmount           Decimal          @default(0) @map("total_amount") @db.Decimal(18, 4)
  goldRateSnapshot      Json?            @map("gold_rate_snapshot")
  pricingSnapshot       Json?            @map("pricing_snapshot")
  exchangeRateSnapshot  Json?            @map("exchange_rate_snapshot")
  reservationId         String?          @map("reservation_id") @db.Uuid
  sellerEmployeeId      String?          @map("seller_employee_id") @db.Uuid
  cashierEmployeeId     String?          @map("cashier_employee_id") @db.Uuid
  loyaltyPointsRedeemed Decimal          @default(0) @map("loyalty_points_redeemed") @db.Decimal(18, 4)
  loyaltyPointsEarned   Decimal          @default(0) @map("loyalty_points_earned") @db.Decimal(18, 4)
  discountPending       Boolean          @default(false) @map("discount_pending")
  checkoutLockedAt      DateTime?        @map("checkout_locked_at") @db.Timestamptz(6)
  notes                 String?          @db.Text
  completedAt           DateTime?        @map("completed_at") @db.Timestamptz(6)
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime?        @map("deleted_at") @db.Timestamptz(6)

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  organization Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  branch       Branch             @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer     Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  employee     Employee?          @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  reservation  Reservation?       @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  seller       Employee?          @relation("SalesOrderSeller", fields: [sellerEmployeeId], references: [id], onDelete: SetNull)
  cashier      Employee?          @relation("SalesOrderCashier", fields: [cashierEmployeeId], references: [id], onDelete: SetNull)
  posSession   PosSession?        @relation(fields: [posSessionId], references: [id], onDelete: SetNull)
  lines        SalesOrderLine[]
  invoices     Invoice[]
  queueEntry   CashierQueueEntry?

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([branchId])
  @@index([customerId])
  @@index([employeeId])
  @@index([sellerEmployeeId])
  @@index([cashierEmployeeId])
  @@index([reservationId])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderDate])
  @@index([tenantId, status, branchId])
  @@map("sales_orders")
}

model SalesOrderLine {
  id              String     @id @default(uuid()) @db.Uuid
  salesOrderId    String     @map("sales_order_id") @db.Uuid
  productId       String     @map("product_id") @db.Uuid
  inventoryItemId String?    @map("inventory_item_id") @db.Uuid
  lineNo          Int        @map("line_no")
  quantity        Int        @default(1)
  unitPrice       Decimal    @map("unit_price") @db.Decimal(18, 4)
  discount        Decimal    @default(0) @db.Decimal(18, 4)
  taxAmount       Decimal    @default(0) @map("tax_amount") @db.Decimal(18, 4)
  totalAmount     Decimal    @map("total_amount") @db.Decimal(18, 4)
  weight          Decimal?   @db.Decimal(12, 4)
  karat           GoldKarat?
  pricingSnapshot Json?      @map("pricing_snapshot")
  notes           String?    @db.Text
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?  @map("deleted_at") @db.Timestamptz(6)

  salesOrder    SalesOrder     @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product       Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@unique([salesOrderId, lineNo])
  @@index([salesOrderId])
  @@index([productId])
  @@index([inventoryItemId])
  @@map("sales_order_lines")
}
