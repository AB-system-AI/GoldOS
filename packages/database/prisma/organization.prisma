// ─── Branches, Employees & Workshops ─────────────────────────────────────────

model Branch {
  id                       String       @id @default(uuid()) @db.Uuid
  tenantId                 String       @map("tenant_id") @db.Uuid
  organizationId           String       @map("organization_id") @db.Uuid
  code                     String       @db.VarChar(20)
  name                     String       @db.VarChar(255)
  type                     BranchType   @default(SHOWROOM)
  branchStatus             BranchStatus @default(ACTIVE) @map("branch_status")
  phone                    String?      @db.VarChar(30)
  email                    String?      @db.VarChar(255)
  isActive                 Boolean      @default(true) @map("is_active")
  isHeadOffice             Boolean      @default(false) @map("is_head_office")
  timezone                 String?      @db.VarChar(50)
  managerId                String?      @map("manager_id") @db.Uuid
  defaultCurrencyCode      String?      @map("default_currency_code") @db.Char(3)
  defaultWarehouseBranchId String?      @map("default_warehouse_branch_id") @db.Uuid
  workingHours             Json         @default("{}") @map("working_hours")
  taxConfiguration         Json         @default("{}") @map("tax_configuration")
  metadata                 Json         @default("{}")
  createdAt                DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                DateTime?    @map("deleted_at") @db.Timestamptz(6)

  tenant                      Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  organization                Organization                 @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  manager                     Employee?                    @relation("BranchManager", fields: [managerId], references: [id], onDelete: SetNull)
  defaultWarehouseBranch      Branch?                      @relation("BranchDefaultWarehouse", fields: [defaultWarehouseBranchId], references: [id], onDelete: SetNull)
  warehouseForBranches        Branch[]                     @relation("BranchDefaultWarehouse")
  userBranches                UserBranch[]
  devices                     Device[]
  employees                   Employee[]
  employeeBranches            EmployeeBranch[]
  employmentHistory           EmploymentHistory[]
  branchCurrencies            BranchCurrency[]
  workshops                   Workshop[]
  inventoryItems              InventoryItem[]
  transfersFrom               Transfer[]                   @relation("TransferFromBranch")
  transfersTo                 Transfer[]                   @relation("TransferToBranch")
  reservations                Reservation[]
  purchaseOrders              PurchaseOrder[]
  salesOrders                 SalesOrder[]
  invoices                    Invoice[]
  cashRegisters               CashRegister[]
  manufacturingOrders         ManufacturingOrder[]
  repairOrders                RepairOrder[]
  barcodeScans                BarcodeScan[]
  thermalPrinters             ThermalPrinter[]
  employeeInvitations         EmployeeInvitation[]
  warehouseZones              WarehouseZone[]
  stockMovements              StockMovement[]
  lifecycleEvents             AssetLifecycleEvent[]
  custodyEvents               CustodyEvent[]
  inventoryAdjustments        InventoryAdjustment[]
  stockCounts                 StockCount[]
  hardwareDeviceProfiles      HardwareDeviceProfile[]
  posSessions                 PosSession[]
  salesReturns                SalesReturn[]
  salesExchanges              SalesExchange[]
  buybackTransactions         BuybackTransaction[]
  payments                    Payment[]
  salesDocumentSequences      SalesDocumentSequence[]
  discountApprovals           DiscountApproval[]
  invoiceTemplates            InvoiceTemplate[]
  cashierQueueEntries         CashierQueueEntry[]
  manualPriceOverrides        ManualPriceOverride[]
  salesEventLogs              SalesEventLog[]
  chartOfAccounts             ChartOfAccount[]
  journalEntries              JournalEntry[]
  accountBalances             AccountBalance[]
  cashRegisterShifts          CashRegisterShift[]
  cashMovements               CashMovement[]
  customerLedgerEntries       CustomerLedgerEntry[]
  supplierLedgerEntries       SupplierLedgerEntry[]
  expenses                    Expense[]
  purchasingDocumentSequences PurchasingDocumentSequence[]
  purchaseRequests            PurchaseRequest[]
  purchaseRfqs                PurchaseRfq[]
  supplierQuotations          SupplierQuotation[]
  goodsReceipts               GoodsReceipt[]
  purchaseInvoices            PurchaseInvoice[]
  purchaseReturns             PurchaseReturn[]
  purchaseApprovalConfigs     PurchaseApprovalConfig[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([organizationId])
  @@index([tenantId, deletedAt])
  @@map("branches")
}

model Employee {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  branchId     String?        @map("branch_id") @db.Uuid
  userId       String?        @unique @map("user_id") @db.Uuid
  managerId    String?        @map("manager_id") @db.Uuid
  departmentId String?        @map("department_id") @db.Uuid
  jobTitleId   String?        @map("job_title_id") @db.Uuid
  photoFileId  String?        @map("photo_file_id") @db.Uuid
  employeeNo   String         @map("employee_no") @db.VarChar(30)
  firstName    String         @map("first_name") @db.VarChar(100)
  lastName     String         @map("last_name") @db.VarChar(100)
  email        String?        @db.VarChar(255)
  phone        String?        @db.VarChar(30)
  jobTitle     String?        @map("job_title") @db.VarChar(100)
  department   String?        @db.VarChar(100)
  hireDate     DateTime?      @map("hire_date") @db.Date
  status       EmployeeStatus @default(ACTIVE)
  notes        String?        @db.Text
  metadata     Json           @default("{}")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?      @map("deleted_at") @db.Timestamptz(6)

  tenant                     Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch                     Branch?                    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user                       User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  manager                    Employee?                  @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports              Employee[]                 @relation("EmployeeManager")
  departmentRef              Department?                @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobTitleRef                JobTitle?                  @relation(fields: [jobTitleId], references: [id], onDelete: SetNull)
  photoFile                  File?                      @relation(fields: [photoFileId], references: [id], onDelete: SetNull)
  invitations                EmployeeInvitation[]
  employeeBranches           EmployeeBranch[]
  employmentHistory          EmploymentHistory[]
  emergencyContacts          EmployeeEmergencyContact[]
  managedBranches            Branch[]                   @relation("BranchManager")
  stockMovements             StockMovement[]
  transfersRequested         Transfer[]                 @relation("TransferRequestedBy")
  transfersApproved          Transfer[]                 @relation("TransferApprovedBy")
  transfersRejected          Transfer[]                 @relation("TransferRejectedBy")
  lifecycleEvents            AssetLifecycleEvent[]
  custodyEvents              CustodyEvent[]
  inventoryLocks             InventoryLock[]
  priceChanges               InventoryPriceHistory[]
  weightChanges              InventoryWeightHistory[]
  adjustmentsRequested       InventoryAdjustment[]      @relation("AdjustmentRequestedBy")
  adjustmentsApproved        InventoryAdjustment[]      @relation("AdjustmentApprovedBy")
  approvalsRequested         InventoryApproval[]        @relation("ApprovalRequestedBy")
  approvalsApproved          InventoryApproval[]        @relation("ApprovalApprovedBy")
  approvalsRejected          InventoryApproval[]        @relation("ApprovalRejectedBy")
  salesOrders                SalesOrder[]
  invoices                   Invoice[]
  payments                   Payment[]
  posSessions                PosSession[]
  salesReturns               SalesReturn[]              @relation("SalesReturnEmployee")
  salesReturnsApproved       SalesReturn[]              @relation("SalesReturnApprover")
  salesExchanges             SalesExchange[]            @relation("SalesExchangeEmployee")
  salesExchangesApproved     SalesExchange[]            @relation("SalesExchangeApprover")
  buybacks                   BuybackTransaction[]       @relation("BuybackEmployee")
  buybacksApproved           BuybackTransaction[]       @relation("BuybackApprover")
  discountApprovalsRequested DiscountApproval[]         @relation("DiscountApprovalRequester")
  discountApprovalsApproved  DiscountApproval[]         @relation("DiscountApprovalApprover")
  salesOrdersSeller          SalesOrder[]               @relation("SalesOrderSeller")
  salesOrdersCashier         SalesOrder[]               @relation("SalesOrderCashier")
  invoicesCashier            Invoice[]                  @relation("InvoiceCashier")
  queueEntriesSeller         CashierQueueEntry[]        @relation("QueueSeller")
  queueEntriesCashier        CashierQueueEntry[]        @relation("QueueCashier")
  manualOverrides            ManualPriceOverride[]      @relation("ManualOverrideCreator")
  journalsCreated            JournalEntry[]             @relation("JournalCreatedBy")
  journalsPosted             JournalEntry[]             @relation("JournalPostedBy")
  journalsReversed           JournalEntry[]             @relation("JournalReversedBy")
  periodsClosed              AccountingPeriod[]         @relation("PeriodClosedBy")
  cashRegisterShifts         CashRegisterShift[]
  cashMovementsFrom          CashMovement[]             @relation("CashMovementFrom")
  cashMovementsTo            CashMovement[]             @relation("CashMovementTo")
  expensesApproved           Expense[]                  @relation("ExpenseApprover")
  bankReconciliations        BankReconciliation[]
  purchaseRequestsRequested  PurchaseRequest[]          @relation("PurchaseRequestRequester")
  purchaseRfqsCreated        PurchaseRfq[]              @relation("PurchaseRfqCreator")
  purchaseOrdersRequested    PurchaseOrder[]            @relation("PurchaseOrderRequester")
  purchaseOrdersApproved     PurchaseOrder[]            @relation("PurchaseOrderApprover")
  goodsReceiptsReceived      GoodsReceipt[]             @relation("GoodsReceiptReceiver")
  purchaseReturnsApproved    PurchaseReturn[]           @relation("PurchaseReturnApprover")
  purchaseApprovals          PurchaseApproval[]         @relation("PurchaseApprovalApprover")

  @@unique([tenantId, employeeNo])
  @@index([tenantId])
  @@index([branchId])
  @@index([status])
  @@index([tenantId, deletedAt])
  @@map("employees")
}

model Workshop {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @map("tenant_id") @db.Uuid
  branchId    String?        @map("branch_id") @db.Uuid
  code        String         @db.VarChar(20)
  name        String         @db.VarChar(255)
  status      WorkshopStatus @default(ACTIVE)
  capacity    Int?
  description String?        @db.Text
  metadata    Json           @default("{}")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?      @map("deleted_at") @db.Timestamptz(6)

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch              Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  manufacturingOrders ManufacturingOrder[]
  repairOrders        RepairOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([branchId])
  @@index([status])
  @@map("workshops")
}
