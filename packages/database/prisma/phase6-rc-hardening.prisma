// ─── Phase 6 RC: Enterprise Sales Hardening ──────────────────────────────────

model CashierQueueEntry {
  id                   String             @id @default(uuid()) @db.Uuid
  tenantId             String             @map("tenant_id") @db.Uuid
  branchId             String             @map("branch_id") @db.Uuid
  salesOrderId         String             @unique @map("sales_order_id") @db.Uuid
  sellerEmployeeId     String?            @map("seller_employee_id") @db.Uuid
  cashierEmployeeId    String?            @map("cashier_employee_id") @db.Uuid
  status               CashierQueueStatus @default(WAITING)
  priority             Int                @default(0)
  estimatedWaitMinutes Int?               @map("estimated_wait_minutes")
  queuePosition        Int?               @map("queue_position")
  queuedAt             DateTime           @default(now()) @map("queued_at") @db.Timestamptz(6)
  calledAt             DateTime?          @map("called_at") @db.Timestamptz(6)
  processingStartedAt  DateTime?          @map("processing_started_at") @db.Timestamptz(6)
  completedAt          DateTime?          @map("completed_at") @db.Timestamptz(6)
  cancelledAt          DateTime?          @map("cancelled_at") @db.Timestamptz(6)
  notes                String?            @db.Text
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?          @map("deleted_at") @db.Timestamptz(6)

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch     Branch     @relation(fields: [branchId], references: [id], onDelete: Restrict)
  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Restrict)
  seller     Employee?  @relation("QueueSeller", fields: [sellerEmployeeId], references: [id], onDelete: SetNull)
  cashier    Employee?  @relation("QueueCashier", fields: [cashierEmployeeId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([branchId])
  @@index([status])
  @@index([priority])
  @@index([queuedAt])
  @@index([tenantId, branchId, status])
  @@map("cashier_queue_entries")
}

model SalesExchangeLine {
  id              String                     @id @default(uuid()) @db.Uuid
  salesExchangeId String                     @map("sales_exchange_id") @db.Uuid
  lineNo          Int                        @map("line_no")
  direction       SalesExchangeLineDirection
  invoiceItemId   String?                    @map("invoice_item_id") @db.Uuid
  inventoryItemId String?                    @map("inventory_item_id") @db.Uuid
  productId       String?                    @map("product_id") @db.Uuid
  buybackId       String?                    @map("buyback_id") @db.Uuid
  quantity        Int                        @default(1)
  amount          Decimal                    @db.Decimal(18, 4)
  weight          Decimal?                   @db.Decimal(12, 4)
  karat           GoldKarat?
  pricingSnapshot Json?                      @map("pricing_snapshot")
  reason          String?                    @db.Text
  createdAt       DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?                  @map("deleted_at") @db.Timestamptz(6)

  salesExchange SalesExchange       @relation(fields: [salesExchangeId], references: [id], onDelete: Cascade)
  invoiceItem   InvoiceItem?        @relation(fields: [invoiceItemId], references: [id], onDelete: SetNull)
  inventoryItem InventoryItem?      @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  product       Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  buyback       BuybackTransaction? @relation(fields: [buybackId], references: [id], onDelete: SetNull)

  @@unique([salesExchangeId, lineNo])
  @@index([salesExchangeId])
  @@map("sales_exchange_lines")
}

model ManualPriceOverride {
  id            String             @id @default(uuid()) @db.Uuid
  tenantId      String             @map("tenant_id") @db.Uuid
  branchId      String             @map("branch_id") @db.Uuid
  referenceType String             @map("reference_type") @db.VarChar(50)
  referenceId   String             @map("reference_id") @db.Uuid
  overrideType  ManualOverrideType @map("override_type")
  fieldName     String             @map("field_name") @db.VarChar(50)
  originalValue Decimal            @map("original_value") @db.Decimal(18, 4)
  overrideValue Decimal            @map("override_value") @db.Decimal(18, 4)
  reason        String             @db.Text
  createdById   String?            @map("created_by_id") @db.Uuid
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch    @relation(fields: [branchId], references: [id], onDelete: Restrict)
  createdBy Employee? @relation("ManualOverrideCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([branchId])
  @@index([referenceType, referenceId])
  @@map("manual_price_overrides")
}

model LoyaltyProgramRule {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  pointsPerCurrency  Decimal  @default(1) @map("points_per_currency") @db.Decimal(18, 4)
  vipMultiplier      Decimal  @default(1.5) @map("vip_multiplier") @db.Decimal(8, 4)
  platinumMultiplier Decimal  @default(2) @map("platinum_multiplier") @db.Decimal(8, 4)
  expirationDays     Int      @default(365) @map("expiration_days")
  redeemRate         Decimal  @default(0.01) @map("redeem_rate") @db.Decimal(18, 6)
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId])
  @@map("loyalty_program_rules")
}

model SalesEventLog {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  branchId      String?        @map("branch_id") @db.Uuid
  userId        String?        @map("user_id") @db.Uuid
  eventType     SalesEventType @map("event_type")
  referenceType String?        @map("reference_type") @db.VarChar(50)
  referenceId   String?        @map("reference_id") @db.Uuid
  title         String         @db.VarChar(255)
  body          String         @db.Text
  payload       Json           @default("{}")
  occurredAt    DateTime       @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([branchId])
  @@index([eventType])
  @@index([occurredAt])
  @@index([referenceType, referenceId])
  @@map("sales_event_logs")
}
