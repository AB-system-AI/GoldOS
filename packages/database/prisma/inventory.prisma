// ─── Inventory Management ────────────────────────────────────────────────────

model InventoryItem {
  id                 String          @id @default(uuid()) @db.Uuid
  tenantId           String          @map("tenant_id") @db.Uuid
  branchId           String          @map("branch_id") @db.Uuid
  productId          String          @map("product_id") @db.Uuid
  inventoryLotId     String?         @map("inventory_lot_id") @db.Uuid
  serialNumber       String          @map("serial_number") @db.VarChar(50)
  barcode            String?         @db.VarChar(50)
  status             InventoryStatus @default(AVAILABLE)
  costPrice          Decimal?        @map("cost_price") @db.Decimal(18, 4)
  sellingPrice       Decimal?        @map("selling_price") @db.Decimal(18, 4)
  goldRateAtPurchase Decimal?        @map("gold_rate_at_purchase") @db.Decimal(12, 4)
  weightActual       Decimal?        @map("weight_actual") @db.Decimal(12, 4)
  location           String?         @db.VarChar(100)
  metadata           Json            @default("{}")
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?       @map("deleted_at") @db.Timestamptz(6)

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  inventoryLot   InventoryLot?   @relation(fields: [inventoryLotId], references: [id], onDelete: SetNull)
  stockMovements StockMovement[]
  transferLines  TransferLine[]
  reservations   Reservation[]
  invoiceItems   InvoiceItem[]

  @@unique([tenantId, serialNumber])
  @@index([tenantId])
  @@index([branchId])
  @@index([productId])
  @@index([status])
  @@index([barcode])
  @@index([tenantId, deletedAt])
  @@map("inventory_items")
}

model InventoryLot {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  lotNumber   String    @map("lot_number") @db.VarChar(50)
  receivedAt  DateTime  @map("received_at") @db.Timestamptz(6)
  expiryAt    DateTime? @map("expiry_at") @db.Timestamptz(6)
  supplierRef String?   @map("supplier_ref") @db.VarChar(100)
  totalWeight Decimal?  @map("total_weight") @db.Decimal(12, 4)
  totalPieces Int       @default(0) @map("total_pieces")
  notes       String?   @db.Text
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  inventoryItems InventoryItem[]

  @@unique([tenantId, lotNumber])
  @@index([tenantId])
  @@index([receivedAt])
  @@map("inventory_lots")
}

model StockMovement {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @map("tenant_id") @db.Uuid
  inventoryItemId String            @map("inventory_item_id") @db.Uuid
  type            StockMovementType
  quantity        Int               @default(1)
  referenceType   String?           @map("reference_type") @db.VarChar(50)
  referenceId     String?           @map("reference_id") @db.Uuid
  notes           String?           @db.Text
  occurredAt      DateTime          @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(6)

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([inventoryItemId])
  @@index([type])
  @@index([occurredAt])
  @@index([referenceType, referenceId])
  @@map("stock_movements")
}

model Transfer {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  transferNo   String         @map("transfer_no") @db.VarChar(30)
  fromBranchId String         @map("from_branch_id") @db.Uuid
  toBranchId   String         @map("to_branch_id") @db.Uuid
  status       TransferStatus @default(DRAFT)
  notes        String?        @db.Text
  shippedAt    DateTime?      @map("shipped_at") @db.Timestamptz(6)
  receivedAt   DateTime?      @map("received_at") @db.Timestamptz(6)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?      @map("deleted_at") @db.Timestamptz(6)

  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  fromBranch Branch         @relation("TransferFromBranch", fields: [fromBranchId], references: [id], onDelete: Restrict)
  toBranch   Branch         @relation("TransferToBranch", fields: [toBranchId], references: [id], onDelete: Restrict)
  lines      TransferLine[]

  @@unique([tenantId, transferNo])
  @@index([tenantId])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([status])
  @@map("transfers")
}

model TransferLine {
  id              String    @id @default(uuid()) @db.Uuid
  transferId      String    @map("transfer_id") @db.Uuid
  inventoryItemId String    @map("inventory_item_id") @db.Uuid
  quantity        Int       @default(1)
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  transfer      Transfer      @relation(fields: [transferId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([transferId])
  @@index([inventoryItemId])
  @@map("transfer_lines")
}

model Reservation {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @map("tenant_id") @db.Uuid
  branchId        String            @map("branch_id") @db.Uuid
  customerId      String            @map("customer_id") @db.Uuid
  inventoryItemId String            @map("inventory_item_id") @db.Uuid
  reservationNo   String            @map("reservation_no") @db.VarChar(30)
  status          ReservationStatus @default(ACTIVE)
  depositAmount   Decimal?          @map("deposit_amount") @db.Decimal(18, 4)
  expiresAt       DateTime          @map("expires_at") @db.Timestamptz(6)
  notes           String?           @db.Text
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(6)

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([tenantId, reservationNo])
  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@index([expiresAt])
  @@map("reservations")
}
